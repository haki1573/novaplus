# NovaPlus+ güvenli ortam ayarları
# Bu dosyayı .env adıyla kopyalayın ve gerçek anahtarı ekleyin.

# 32 bayt Base64 anahtar.
# Oluşturma komutu:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BACKUP_ENCRYPTION_KEY=

BACKUP_INTERVAL_MS=300000
BACKUP_RETENTION_COUNT=30
BACKUP_DIRECTORY=backups
DATABASE_PATH=database.db
UPLOADS_DIRECTORY=uploads
APP_VERSION=4.1.1

# Security 3.1 JWT anahtarı için güçlü ve farklı bir değer kullanın.
JWT_SECRET=
